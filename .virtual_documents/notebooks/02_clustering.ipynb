


import numpy as np
import pandas as pd
import plotly.express as px

df = pd.read_csv('../data/processed/clustered.csv')
print(df.shape, df.columns.tolist())


fig = px.scatter(
    df, x='umap_x', y='umap_y',
    color='cluster', hover_data=['title', 'score'],
    title='UMAP 2D — Stilkluster',
    color_continuous_scale='rainbow',
)
fig.show()


# Score per cluster — vilka stilar premieras?
cluster_stats = df.groupby('cluster')['score'].agg(['mean', 'median', 'count'])
cluster_stats.sort_values('mean', ascending=False)


%matplotlib inline
import matplotlib.pyplot as plt
from PIL import Image
from pathlib import Path

ROOT = Path('/Users/antonhergefeldt/ws/street_photo_scorer')

n_clusters = df['cluster'].nunique()
fig, axes = plt.subplots(n_clusters, 3, figsize=(14, n_clusters * 5))

for cluster_id in range(n_clusters):
    top = df[df['cluster'] == cluster_id].nlargest(3, 'score')
    for col, (_, row) in enumerate(top.iterrows()):
        ax = axes[cluster_id][col]
        try:
            img = Image.open(ROOT / row['local_path'])
            ax.imshow(img)
        except Exception as e:
            ax.text(0.5, 0.5, 'saknas', ha='center', va='center', transform=ax.transAxes)
        ax.set_xlabel(f"score: {int(row['score'])}", fontsize=10, labelpad=4)
        ax.set_xticks([])
        ax.set_yticks([])
        for spine in ax.spines.values():
            spine.set_visible(False)
    axes[cluster_id][0].set_ylabel(f'Cluster {cluster_id}', fontsize=12, rotation=0, labelpad=55)

fig.suptitle('Top photos per cluster', fontsize=16, y=1.01)
plt.tight_layout()
plt.show()
